# {{ ansible_managed | default('Generated by AutoShift create-cluster-values playbook') }}
# Cluster: {{ cluster_name }}
{% if disconnected | bool %}
# Environment: Disconnected
{% endif %}
{% set _use_mac = (port_selection | default('name')) == 'mac' %}
{% set _host0 = cluster_hosts[0] %}
{% set _bonded = (cluster_nic_count | int) > 1 %}
{% set _cluster_base = 'bond0' if _bonded else _host0.nic1_name | default('eno1') %}
{% set _cluster_vlan_name = _cluster_base ~ '.' ~ cluster_vlan_id %}

clusters:
  {{ cluster_name }}:
    config:
      clusterSet: {{ cluster_set }}

      # =====================================================================
      # Networking
      # =====================================================================
      networking:
        clusterNetwork:
          cidr: {{ cluster_network_cidr }}
          hostPrefix: {{ cluster_network_prefix }}
        machineNetwork:
          cidr: '{{ machine_network_cidr }}'
        serviceNetwork:
          - {{ service_network_cidr }}

        interfaces:
{% if _bonded %}
          nic1:
            type: ethernet
            name: {{ _host0.nic1_name | default('eno1') }}
{% if _use_mac %}
            mac: '{{ _host0.nic1_mac }}'
{% endif %}
            state: up
            ipv4: disabled
            ipv6: disabled
          nic2:
            type: ethernet
            name: {{ _host0.nic2_name | default('eno2') }}
{% if _use_mac %}
            mac: '{{ _host0.nic2_mac }}'
{% endif %}
            state: up
            ipv4: disabled
            ipv6: disabled
          cluster-bond:
            type: bond
            name: bond0
            state: up
            mode: {{ cluster_bond_mode }}
            mtu: {{ cluster_vlan_mtu }}
            miimon: {{ cluster_bond_miimon }}
            ports:
              - {{ _host0.nic1_name | default('eno1') }}
              - {{ _host0.nic2_name | default('eno2') }}
            ipv4: disabled
            ipv6: disabled
{% endif %}
          cluster-vlan:
            type: vlan
            name: {{ _cluster_vlan_name }}
            id: {{ cluster_vlan_id }}
            base: {{ _cluster_base }}
            mtu: {{ cluster_vlan_mtu }}
            ipv4: {{ cluster_vlan_ipv4 }}
            ipv6: disabled
{% if storage_vlan | bool %}
{% set _storage_dedicated = not (storage_shared_nics | bool) %}
{% set _storage_bonded = (storage_nic_count | int) > 1 if _storage_dedicated else _bonded %}
{% if _storage_dedicated %}
{% set _storage_base = 'bond1' if _storage_bonded else _host0.nic3_name | default('ens1f0') %}
{% if _storage_bonded %}
          storage-nic1:
            type: ethernet
            name: {{ _host0.nic3_name | default('ens1f0') }}
{% if _use_mac %}
            mac: '{{ _host0.nic3_mac }}'
{% endif %}
            state: up
            ipv4: disabled
            ipv6: disabled
          storage-nic2:
            type: ethernet
            name: {{ _host0.nic4_name | default('ens1f1') }}
{% if _use_mac %}
            mac: '{{ _host0.nic4_mac }}'
{% endif %}
            state: up
            ipv4: disabled
            ipv6: disabled
          storage-bond:
            type: bond
            name: bond1
            state: up
            mode: {{ storage_bond_mode }}
            mtu: {{ storage_vlan_mtu }}
            miimon: {{ storage_bond_miimon }}
            ports:
              - {{ _host0.nic3_name | default('ens1f0') }}
              - {{ _host0.nic4_name | default('ens1f1') }}
            ipv4: disabled
            ipv6: disabled
{% endif %}
{% else %}
{% set _storage_base = _cluster_base %}
{% endif %}
          storage-vlan:
            type: vlan
            name: {{ _storage_base }}.{{ storage_vlan_id }}
            id: {{ storage_vlan_id }}
            base: {{ _storage_base }}
            mtu: {{ storage_vlan_mtu }}
            ipv4: {{ storage_vlan_ipv4 }}
            ipv6: disabled
{% endif %}

{% if dns_servers | length > 0 %}
        dns:
          servers:
{% for server in dns_servers %}
            - {{ server }}
{% endfor %}
{% if dns_search | length > 0 %}
          search:
{% for domain in dns_search %}
            - {{ domain }}
{% endfor %}
{% endif %}
{% endif %}

{% if default_gateway | default('') != '' %}
        routes:
          default:
            destination: 0.0.0.0/0
            gateway: '{{ default_gateway }}'
            interface: {{ _cluster_vlan_name }}
{% endif %}

      # =====================================================================
      # Hosts
      # =====================================================================
      hosts:
{% for host in cluster_hosts %}
        {{ host.hostname }}:
          bmcIP: '{{ host.bmc_ip }}'
          bmcPrefix: '{{ host.bmc_prefix }}'
          bootMACAddress: '{{ host.boot_mac }}'
          primaryMac: '{{ host.nic1_mac }}'
{% if host.role | default('master') != 'master' %}
          role: {{ host.role }}
{% endif %}
{% if host.root_device_hint | default({}) | length > 0 %}
          rootDeviceHints:
{% if host.root_device_hint.serialNumber | default('') != '' %}
            serialNumber: '{{ host.root_device_hint.serialNumber }}'
{% elif host.root_device_hint.minSizeGigabytes | default(0) | int > 0 %}
            minSizeGigabytes: {{ host.root_device_hint.minSizeGigabytes }}
{% elif host.root_device_hint.deviceName | default('') != '' %}
            deviceName: '{{ host.root_device_hint.deviceName }}'
{% endif %}
{% endif %}
          interfaces:
            - macAddress: '{{ host.nic1_mac }}'
              name: '{{ host.nic1_name | default("eno1") }}'
{% if _bonded %}
            - macAddress: '{{ host.nic2_mac }}'
              name: '{{ host.nic2_name | default("eno2") }}'
{% endif %}
{% if storage_vlan | bool and not storage_shared_nics | bool %}
            - macAddress: '{{ host.nic3_mac }}'
              name: '{{ host.nic3_name | default("ens1f0") }}'
{% if (storage_nic_count | int) > 1 %}
            - macAddress: '{{ host.nic4_mac }}'
              name: '{{ host.nic4_name | default("ens1f1") }}'
{% endif %}
{% endif %}
{% if (cluster_vlan_ipv4 == 'static' and host.cluster_ip | default('') != '') or (storage_vlan | bool and storage_vlan_ipv4 == 'static' and host.storage_ip | default('') != '') %}
          networking:
            interfaces:
{% if cluster_vlan_ipv4 == 'static' and host.cluster_ip | default('') != '' %}
              cluster-vlan:
                ipv4:
                  addresses:
                    - ip: {{ host.cluster_ip }}
                      prefixLength: {{ host.cluster_prefix | default(25) }}
{% endif %}
{% if storage_vlan | bool and storage_vlan_ipv4 == 'static' and host.storage_ip | default('') != '' %}
              storage-vlan:
                ipv4:
                  addresses:
                    - ip: {{ host.storage_ip }}
                      prefixLength: {{ host.storage_prefix | default(24) }}
{% endif %}
{% endif %}
{% endfor %}

{% if disconnected | bool %}
      # =====================================================================
      # Disconnected
      # =====================================================================
      disconnected:
        mirrorRegistry:
          host: '{{ mirror_registry_host }}'
          path: '{{ mirror_registry_path }}'
{% if mirror_ca_ref_name != '' %}
          caRef:
            name: '{{ mirror_ca_ref_name }}'
            key: '{{ mirror_ca_ref_key }}'
            namespace: '{{ mirror_ca_ref_namespace }}'
{% endif %}
          mirrors:
{% for entry in mirror_entries %}
            - source: {{ entry.source }}
{% if entry.mirror is defined %}
              mirror: {{ entry.mirror }}
{% endif %}
{% endfor %}
        useIDMS: true
        disableDefaultCatalogs: {{ disable_default_catalogs | lower }}
        catalogs:
{% for catalog in catalog_entries %}
          - source: {{ catalog.source }}
            imagePath: {{ catalog.image_path }}
            tag: {{ catalog.tag }}
            publisher: {{ catalog.publisher }}
            displayName: '{{ catalog.display_name }}'
{% endfor %}
{% endif %}

      # =====================================================================
      # Cluster Install
      # =====================================================================
      clusterInstall:
        createCluster: 'true'
        platform: baremetal
        baseDomain: {{ base_domain }}
        openshiftVersion: '{{ openshift_version }}'
        cpuArch: {{ cpu_arch }}
{% if cpu_partitioning | default('None') == 'AllNodes' %}
        cpuPartitioning: 'AllNodes'
{% endif %}

        controlPlaneAgents: {{ control_plane_agents }}
{% if worker_agents | int > 0 %}
        workerAgents: {{ worker_agents }}
{% endif %}
{% if control_plane_agents | int > 1 %}
        apiVip: '{{ api_vip }}'
        ingressVip: '{{ ingress_vip }}'
{% endif %}
{% if masters_schedulable | bool %}
        mastersSchedulable: true
{% endif %}

        sshPublicKey: '{{ ssh_public_key }}'
        pullSecretRef: '{{ pull_secret_ref }}'
        bmcCredentialRef: '{{ bmc_credential_ref }}'
        bmcEndpoint: '{{ bmc_endpoint }}'
        secretSourceNamespace: '{{ secret_source_namespace }}'
{% if ntp_sources | length > 0 %}
        ntpSources:
{% for ntp in ntp_sources %}
          - {{ ntp }}
{% endfor %}
{% endif %}
