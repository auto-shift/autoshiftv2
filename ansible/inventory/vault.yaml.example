---
# ==============================================================================
# Ansible Vault encrypted credentials
# ==============================================================================
# Copy this file and encrypt it:
#   cp ansible/inventory/vault.yaml.example ansible/inventory/vault.yaml
#   ansible-vault encrypt ansible/inventory/vault.yaml
#
# Then edit with:
#   ansible-vault edit ansible/inventory/vault.yaml
#
# Run playbooks with:
#   ansible-playbook playbook.yaml --ask-vault-pass
#   ansible-playbook playbook.yaml --vault-password-file .vault-pass
# ==============================================================================

# iDRAC credentials
idrac_user: admin
idrac_pass: changeme

# Git credentials (for pushing to GitLab)
# git_user: autoshift
# git_email: autoshift@example.com
