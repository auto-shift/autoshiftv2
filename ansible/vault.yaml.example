---
# ==============================================================================
# Ansible Vault encrypted credentials
# ==============================================================================
# Copy this file and encrypt it:
#   cp ansible/vault.yaml.example ansible/vault.yaml
#   ansible-vault encrypt ansible/vault.yaml
#
# Then edit with:
#   ansible-vault edit ansible/vault.yaml
#
# Run playbooks with:
#   ansible-playbook playbook.yaml --ask-vault-pass
#   ansible-playbook playbook.yaml --vault-password-file .vault-pass
# ==============================================================================

# BMC/iDRAC credentials (used by both discovery and cluster install secrets)
idrac_user: admin
idrac_pass: changeme

# Container registry credentials (generates pull secret)
init_secrets_registry: registry.redhat.io
init_secrets_registry_user: your-username
init_secrets_registry_pass: your-token

# SSH keypair — provide existing keys OR leave blank to auto-generate
# If blank, a new ECDSA-521 keypair is generated (FIPS compliant)
# init_secrets_ssh_private_key: |
#   -----BEGIN EC PRIVATE KEY-----
#   ...
#   -----END EC PRIVATE KEY-----
# init_secrets_ssh_public_key: "ecdsa-sha2-nistp521 AAAAE2..."
